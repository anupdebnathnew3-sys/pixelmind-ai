# ─── PixelMind AI — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Base URL (optional) ─────────────────────────────────────────────────────
# Leave blank for custom domain deployment (e.g. https://pixelmindai.com)
# Set to /repo-name/ for GitHub Pages subdirectory deployment
# Example: VITE_BASE_URL=/pixelmind-ai/
VITE_BASE_URL=

# ─── App Identity ─────────────────────────────────────────────────────────────
VITE_APP_NAME=PixelMind AI
VITE_APP_URL=https://pixelmindai.com

# ─── System API Keys (baked into build — available to ALL users on all devices) ─
# Add these as GitHub repository Secrets (Settings → Secrets → Actions)
# Only set the provider(s) you want to use. Model is optional (defaults shown).
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.5-flash-preview-05-20
VITE_GROQ_API_KEY=
VITE_GROQ_MODEL=meta-llama/llama-4-maverick-17b-128e-instruct
VITE_CLAUDE_API_KEY=
VITE_CLAUDE_MODEL=claude-sonnet-4-6
VITE_OPENROUTER_API_KEY=
VITE_OPENROUTER_MODEL=openai/gpt-4o
VITE_MISTRAL_API_KEY=
VITE_MISTRAL_MODEL=pixtral-large-latest

# ─── Firebase (Google Authentication) ────────────────────────────────────────
# Get these from: console.firebase.google.com → Your Project → Project Settings → Web App
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# ─── AI API Keys (optional — users can also add keys via the Admin Panel UI) ─
# These are NOT required. API keys can be managed from the Admin Panel > API Settings.
# If set here, they pre-populate the system key pool.
# VITE_OPENAI_API_KEY=sk-...
# VITE_ANTHROPIC_API_KEY=sk-ant-...
# VITE_GOOGLE_GEMINI_API_KEY=AIza...
